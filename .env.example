# AI Debate Arena — environment configuration
# ---------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored and must
# NEVER be committed. For HF Spaces deployment, add these same three variables as
# Repository secrets (Settings → Repository secrets) — see Spec 04 §6.
#
# The app works with ANY OpenAI-compatible provider. Set these three values to point
# at whichever provider you want; agents reference the model via the `openai/`
# LiteLLM prefix, which LiteLLM routes to OPENAI_API_BASE automatically.

# --- LLM provider (OpenAI-compatible) ---
# The provider's chat-completions endpoint. Examples:
#   Groq free tier (documented default):  https://api.groq.com/openai/v1
#   OpenAI:                              https://api.openai.com/v1
#   OpenRouter:                          https://openrouter.ai/api/v1
#   Ollama (local):                      http://localhost:11434/v1
#   LM Studio (local):                   http://localhost:1234/v1
OPENAI_API_BASE=https://api.groq.com/openai/v1

# API key for the provider above (Groq free-tier key by default). Get a Groq key at:
#   https://console.groq.com/keys
OPENAI_API_KEY=your-key-here

# Model id WITHOUT the openai/ prefix. Examples:
#   Groq default:   llama-3.3-70b-versatile
#   OpenAI:         gpt-4o-mini
#   OpenRouter:     openai/gpt-4o-mini          (OpenRouter uses vendor/model ids)
#   Ollama:         llama3.1:8b
MODEL_NAME=llama-3.3-70b-versatile
